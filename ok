local function getFreeSnapPoints()
    local plot = getMyPlot()
    if not plot then return {} end
    local furniture = plot:FindFirstChild("Furniture")
    local stock = plot:FindFirstChild("Stock")
    if not furniture then return {} end
    local usedSnaps = {}
    if stock then
        for _, item in ipairs(stock:GetChildren()) do
            local sg = item:GetAttribute("ShelfGUID")
            local sp = item:GetAttribute("SnapPointName")
            if sg and sp then usedSnaps[sg.."|"..sp] = true end
        end
    end
    local snaps = {}
    for _, surface in ipairs(furniture:GetChildren()) do
        local itemId = tostring(surface:GetAttribute("ItemId") or "")
        local def = FurnitureModule.Items[itemId]
        if def and def.Category == "Shelves" and selectedShelves[def.Name] then
            local guid = surface:GetAttribute("GUID")
            for _, desc in ipairs(surface:GetDescendants()) do
                if desc:IsA("Attachment") and desc.Name:match("^SnapPoint") then
                    local key = guid.."|"..desc.Name
                    if not usedSnaps[key] then
                        table.insert(snaps, { cf = desc.WorldCFrame, snapName = desc.Name, shelfGUID = guid })
                    end
                end
            end
        end
    end
    return snaps
