-- Single attempt to join an auction. Returns true if joined, false if failed.
local function attemptJoinAuction()
    if currentState ~= AuctionState.SEARCHING then
        return false
    end
    if stateLock then return false end
    stateLock = true

    local success = false
    local function cleanup()
        stateLock = false
        if not success then
            currentState = AuctionState.SEARCHING
        end
    end

    -- Find garage
    local bestGarage, cheapestCost = findBestAffordableGarage(selectedArea, selectedGarageId)
    local cash = player:GetAttribute("Cash") or 0
    if not bestGarage then
        if cheapestCost ~= math.huge and cash < cheapestCost then
            notify("Auto Farm — Need $" .. tostring(math.floor(cheapestCost)) .. " to enter, have $" .. tostring(math.floor(cash)) .. ". Waiting...")
        else
            local areaLabel = selectedArea or "Unknown"
            if selectedGarageId then
                local garageData = GarageConfig[selectedGarageId]
                if garageData then
                    areaLabel = areaLabel .. " - " .. garageData.Name
                end
            end
            notify("Auto Farm — No garage found for " .. areaLabel .. ", retrying...")
        end
        cleanup()
        return false
    end

    local prompt = bestGarage:FindFirstChild("EnterAuction", true)
    if not prompt then
        notify("Auto Farm — No entry prompt found, retrying...")
        cleanup()
        return false
    end

    -- Move character near prompt
    local promptParent = prompt.Parent
    local promptParentCFrame = promptParent:IsA("BasePart") and promptParent.CFrame or promptParent:GetPivot()
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    hrp.CFrame = CFrame.new(promptParentCFrame.Position + Vector3.new(0, 3, 0))
    task.wait(0.3)

    if inAuction then
        -- Already in auction somehow
        currentState = AuctionState.IN_AUCTION
        success = true
        cleanup()
        return true
    end

    -- Fire prompt
    fireproximityprompt(prompt)
    local label = selectedArea or "Unknown"
    if selectedGarageId then
        local garageData = GarageConfig[selectedGarageId]
        if garageData then
            label = label .. " - " .. garageData.Name
        end
    end
    notify("Auto Farm — Joining " .. label .. " auction")

    -- Set state to JOINING and wait for inAuction
    currentState = AuctionState.JOINING
    local start = os.clock()
    local timeout = 8 -- seconds
    while not inAuction and os.clock() - start < timeout do
        task.wait(0.1)
    end

    if inAuction then
        currentState = AuctionState.IN_AUCTION
        success = true
        notify("Auto Farm — Joined auction")
    else
        notify("Auto Farm — Failed to join auction (timeout)")
        currentState = AuctionState.SEARCHING
        success = false
    end

    cleanup()
    return success
end

local function processContainer()
    if currentState ~= AuctionState.IN_AUCTION and currentState ~= AuctionState.PROCESSING then
        return
    end
    currentState = AuctionState.PROCESSING

    local ok, err = pcall(function()
        local allItems = getCarryables()
        local boxes = {}
        for _, model in ipairs(allItems) do
            if model:FindFirstChild("OpenBoxPrompt", true) then
                table.insert(boxes, model)
            end
        end
        if #boxes > 0 then
            notify("Auto Farm — Opening " .. tostring(#boxes) .. " box(es)")
            openBoxes(boxes)
            local opened = waitForBoxesOpened(30)
            if not opened then
                notify("Auto Farm — Boxes did not open in time, continuing anyway")
            end
            task.wait(0.5)
        end

        allItems = getCarryables()
        local repairItems = {}
        for _, model in ipairs(allItems) do
            local guid = model:GetAttribute("ItemsWonGUID")
            if guid and RepairWonItem then
                table.insert(repairItems, model)
            end
        end
        if #repairItems > 0 then
            notify("Auto Farm — Repairing " .. tostring(#repairItems) .. " item(s)")
            for _, model in ipairs(repairItems) do
                local guid = model:GetAttribute("ItemsWonGUID")
                if guid then
                    RepairWonItem:InvokeServer(guid)
                    task.wait(0.2)
                end
            end
            local repaired = waitForRepairsComplete(15)
            if not repaired then
                notify("Auto Farm — Repairs did not finish in time")
            end
            task.wait(0.5)
        end

        allItems = getCarryables()
        local toPickup = {}
        for _, model in ipairs(allItems) do
            table.insert(toPickup, model)
        end
        if #toPickup > 0 then
            if getVehicleDistance() > 10 then
                notify("Auto Farm — Car too far, respawning")
                spawnAndEnterCar()
            end
            notify("Auto Farm — Picking up " .. tostring(#toPickup) .. " item(s)")
            pickupAll(toPickup)
            local picked = waitForNoCarryables(30)
            if not picked then
                notify("Auto Farm — Some items not picked up, continuing")
            end
            task.wait(0.5)
        end

        if isVehicleFull() then
            notify("Auto Farm — Vehicle full, unloading")
            doUnload()
            local unloaded = waitForUnloadComplete(10)
            if not unloaded then
                notify("Auto Farm — Unload did not complete in time")
            end
            task.wait(0.5)
        end

        if autoWashEnabled then
            runAutoWash()
            task.wait(1)
        end
        if autoGradeEnabled then
            runAutoGrade()
            task.wait(1)
        end
        if autoPlaceItems then
            if ActionQueue.acquire("AutoPlace", 2) then
                placeAllItems()
                ActionQueue.release("AutoPlace")
                task.wait(1)
            end
        end

        fullGarageDump()
    end)

    if not ok then
        notify("Auto Farm — Container processing error: " .. tostring(err))
    end

    currentState = AuctionState.FINISHED
end

local function waitForBoxesOpened(timeout)
    timeout = timeout or 30
    local start = tick()
    while tick() - start < timeout do
        local hasPrompt = false
        for _, model in ipairs(getCarryables()) do
            if model:FindFirstChild("OpenBoxPrompt", true) then
                hasPrompt = true
                break
            end
        end
        if not hasPrompt then return true end
        task.wait(0.2)
    end
    return false
end

local function waitForRepairsComplete(timeout)
    timeout = timeout or 15
    local start = tick()
    while tick() - start < timeout do
        local hasRepair = false
        for _, model in ipairs(getCarryables()) do
            if model:GetAttribute("ItemsWonGUID") then
                hasRepair = true
                break
            end
        end
        if not hasRepair then return true end
        task.wait(0.3)
    end
    return false
end

local function waitForNoCarryables(timeout)
    timeout = timeout or 30
    local start = tick()
    while tick() - start < timeout do
        local count = 0
        for _, model in ipairs(getCarryables()) do
            if model:GetAttribute("Owner") == userId then
                count = count + 1
            end
        end
        if count == 0 then return true end
        task.wait(0.3)
    end
    return false
end

local function waitForUnloadComplete(timeout)
    timeout = timeout or 10
    local start = tick()
    while tick() - start < timeout do
        if not vehicleHasItems() then return true end
        task.wait(0.3)
    end
    return false
end

local function startMasterLoop()
    if masterLoopRunning then return end
    if not (autoFarmEnabled or autoFarmEverything) then return end

    masterLoopRunning = true
    masterLoopCoroutine = task.spawn(function()
        while autoFarmEnabled or autoFarmEverything do
            if currentState == AuctionState.SEARCHING then
                local joined = attemptJoinAuction()
                if not joined then
                    -- Wait a bit before retrying
                    task.wait(1)
                end
            elseif currentState == AuctionState.IN_AUCTION then
                -- Wait until auction ends (inAuction becomes false)
                while inAuction do
                    task.wait(0.5)
                end
                -- Auction ended, process container
                processContainer()
                -- After processing, state will be FINISHED
            elseif currentState == AuctionState.JOINING then
                -- Wait for join to finish (handled in attemptJoinAuction)
                task.wait(0.5)
            elseif currentState == AuctionState.PROCESSING then
                task.wait(0.5)
            elseif currentState == AuctionState.FINISHED then
                currentState = AuctionState.SEARCHING
            end
            task.wait(0.1)
        end
        masterLoopRunning = false
        masterLoopCoroutine = nil
    end)
end

