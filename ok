local function shouldPlaceItem(entry, itemDef)
    local mutators = getMutators(entry.Mutators)
    if placeBlacklist.Favorited and entry.Favorited then return false end
    if placeBlacklist.Mutated and hasMutators(mutators) then return false end
    if placeBlacklist.Broken and isBroken(mutators) then return false end
    if placeBlacklist.Dirty and isDirty(mutators) then return false end
    if placeBlacklist.Safes and entry.SafeId ~= nil then return false end
    local category = itemDef.Category
    if placeBlacklist.Consumables and category == "Consumables" then return false end
    if placeBlacklist.Accessories and category == "Accessories" then return false end
    if placeBlacklist.Vehicles and (category == "Vehicles" or category == "Car Parts") then return false end
    if placeBlacklist.Drinks and category == "Drinks" then return false end

    if autoGradeBeforePlace then
        if not entry.Grade or entry.Grade == "" then return false end
    end

    if autoCleanBeforePlace then
        if isDirty(mutators) then return false end
    end

    return true
end

