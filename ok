local function findBestAffordableGarage(areaName, garageId)
    local debris = workspace:FindFirstChild("_Debris")
    local garages = debris and debris:FindFirstChild("Garages")
    if not garages then return nil, nil end

    local areaData = Areas[areaName]
    if not areaData then return nil, nil end

    local cash = player:GetAttribute("Cash") or 0
    local bestGarage = nil
    local bestCost = -1
    local cheapestCost = math.huge

    local garageIds = {}
    if garageId then
        table.insert(garageIds, garageId)
    else
        if areaData.GarageIds then
            for id in pairs(areaData.GarageIds) do
                table.insert(garageIds, id)
            end
        elseif areaData.SimpleGarageId then
            table.insert(garageIds, areaData.SimpleGarageId)
        end
    end

    for _, model in ipairs(garages:GetChildren()) do
        if model:IsA("Model") then
            local modelName = model.Name
            local isInArea = false
            for _, id in ipairs(garageIds) do
                if modelName == id or model:GetAttribute("GarageId") == id then
                    isInArea = true
                    break
                end
            end
            if isInArea then
                local cost = model:GetAttribute("EntryCost") or 0
                if cost < cheapestCost then cheapestCost = cost end
                if cost <= cash and cost > bestCost then
                    local prompt = model:FindFirstChild("EnterAuction", true)
                    if prompt and prompt:IsA("ProximityPrompt") and prompt.Enabled then
                        bestCost = cost
                        bestGarage = model
                    end
                end
            end
        end
    end
    return bestGarage, cheapestCost
end

