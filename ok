    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local plots = workspace:FindFirstChild("_Plots")
    if not plots then return false end
    for _, plot in ipairs(plots:GetChildren()) do
        if plot:GetAttribute("OwnerUserId") == userId then
            local base = plot:FindFirstChild("Base")
            local floor = base and base:FindFirstChild("Floor")
            if floor and floor:IsA("BasePart") then
                local plotPos = floor.Position
                local playerPos = hrp.Position
                local size = floor.Size
                local inX = math.abs(playerPos.X - plotPos.X) <= size.X / 2
                local inZ = math.abs(playerPos.Z - plotPos.Z) <= size.Z / 2
                local inY = playerPos.Y >= plotPos.Y and playerPos.Y <= plotPos.Y + 10
                if inX and inZ and inY then return true end
            end
        end
    end
    return false
end

