local function spawnAndEnterCar()
    local rawId = getVehicleId()
    if not rawId or not RequestSpawn then return false end
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local originalCFrame = hrp.CFrame
    hrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -15)
    task.wait(0.1)
    local bestGarage = findBestAffordableGarage(selectedArea, selectedGarageId)
    local garageParts = bestGarage and bestGarage:FindFirstChild("Parts")
    local running = true
    task.spawn(function()
        while running do
            if char then
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
            local vm = getVehicleModel()
            if vm then
                for _, part in ipairs(vm:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
            if garageParts then
                for _, part in ipairs(garageParts:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
            task.wait()
        end
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = true end
            end
        end
        local vm = getVehicleModel()
        if vm then
            for _, part in ipairs(vm:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = true end
            end
        end
        if garageParts then
            for _, part in ipairs(garageParts:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = true end
            end
        end
    end)
    RequestSpawn:FireServer(rawId)
    task.wait(2)
    local vm = getVehicleModel()
    if vm then
        local seat = vm:FindFirstChildOfClass("VehicleSeat", true)
        if seat and hrp then
            hrp.CFrame = seat.CFrame * CFrame.new(0, 2, 0)
        end
    end
    local entered = waitUntilDriving(10)
    running = false
    if not entered then
        hrp.CFrame = originalCFrame
    end
    return entered
end

