local function shouldBid()
    local cash = player:GetAttribute("Cash") or 0
    if bidMode == "Always" then
        return cash > 0
    elseif bidMode == "Profitable" then
        local itemName = getAuctionItemName()
        if not itemName then return false end
        local def = getItemDefFromName(itemName)
        return def and def.BasePrice and def.BasePrice > 0 and cash >= def.BasePrice
    elseif bidMode == "Specific" then
        local itemName = getAuctionItemName()
        if not itemName then return false end
        local normItem = normalize(itemName)
        for _, target in ipairs(specificItemNames) do
            if target ~= "" and normalize(target) == normItem then return cash > 0 end
        end
        return false
    end
    return false
end

