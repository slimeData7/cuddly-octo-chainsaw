autoPickupToggle = farmingTab:CreateToggle({
    Name = "Auto Pickup",
    CurrentValue = false,
    Flag = "AutoPickupToggle",
    Callback = function(val)
        autoPickupEnabled = val
        if val and not pickupLoopRunning then
            pickupLoopRunning = true
            task.spawn(function()
                while autoPickupEnabled do
                    if not inAuction then
                        local allItems = getCarryables()
                        if #allItems == 0 then task.wait(1) continue end
                        openBoxes(allItems)
                        local resolved = waitForBoxesResolved(8)
                        if not resolved then
                            notify("Auto Pickup — Some boxes took too long, continuing anyway")
                        end
                        allItems = getCarryables()
                        local eligible = {}
                        for _, model in ipairs(allItems) do
                            if getCarryableValue(model) >= minPickupValue then
                                table.insert(eligible, model)
                            end
                        end
                        if #eligible == 0 then
                            notify("Auto Pickup — No items meet min value $" .. tostring(minPickupValue))
                            task.wait(1)
                            continue
                        end
                        local currentWeight, maxWeight = getVehicleCurrentWeight()
                        if maxWeight > 0 and currentWeight >= maxWeight then
                            notify("Auto Pickup — Vehicle overweight, skipping")
                            task.wait(1)
                            continue
                        end
                        if getVehicleDistance() > 10 then
                            notify("Auto Pickup — Car too far, respawning")
                            spawnAndEnterCar()
                        end
                        for _, model in ipairs(eligible) do
                            local guid = model:GetAttribute("ItemsWonGUID")
                            if guid and RepairWonItem then
                                RepairWonItem:InvokeServer(guid)
                                task.wait(0.3 + math.random() * 0.2)
                            end
                        end
                        notify("Auto Pickup — Picking up " .. tostring(#eligible) .. " item(s)")
                        pickupAll(eligible)
                        notify("Auto Pickup — Done")
                        task.wait(0.5)
                    else
                        task.wait(1)
                    end
                end
                pickupLoopRunning = false
            end)
        end
    end,
})

