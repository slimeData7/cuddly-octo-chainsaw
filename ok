local function runAutoWash()
    if not GetWashSlotState or not GetWashableItems or not StartWash then return end
    local state = GetWashSlotState:InvokeServer()
    if type(state) ~= "table" then return end
    local unlockedCount = state.unlockedCount or 1
    local slots = state.slots or {}
    local freeSlots = {}
    local now = workspace:GetServerTimeNow()
    for i = 1, unlockedCount do
        local slotData = slots[tostring(i)] or slots[i]
        if not slotData then
            table.insert(freeSlots, i)
        elseif slotData.Washed then
            ClaimWashedItem:InvokeServer(i)
            task.wait(0.3)
            table.insert(freeSlots, i)
        else
            local done = now >= (slotData.StartTime or 0) + (slotData.Duration or 0)
            if done then
                CollectWash:InvokeServer(i)
                task.wait(0.5)
                ClaimWashedItem:InvokeServer(i)
                task.wait(0.3)
                table.insert(freeSlots, i)
            end
        end
    end
    if #freeSlots == 0 then return end
    local result = GetWashableItems:InvokeServer()
    if type(result) ~= "table" or type(result.items) ~= "table" then return end
    local filtered = {}
    for _, item in ipairs(result.items) do
        local mutators = getMutators(item.data.Mutators)
        if isBroken(mutators) then continue end
        if hasMutators(mutators) then continue end
        local rarity = itemRarity(item.data.ItemId)
        if allWashRarities or selectedWashRarities[rarity] then table.insert(filtered, item) end
    end
    local slotIndex = 1
    local washed = 0
    for _, item in ipairs(filtered) do
        if slotIndex > #freeSlots then break end
        local slot = freeSlots[slotIndex]
        local res = StartWash:InvokeServer(slot, item.guid, item.source, item.vehicleGUID or nil)
        if res and res.success then slotIndex += 1 washed += 1 end
        task.wait(0.3)
    end
    if washed > 0 then notify("Auto Wash — Washing " .. tostring(washed) .. " item(s)") end
end

