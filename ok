local function calcPrice(basePrice, entry)
    local price = MutatorModule:CalculatePriceForEntry(basePrice, entry)
    local grade = entry.Grade
    if grade and GradingConfig.GradeMultipliers and GradingConfig.GradeMultipliers[grade] then
        price = math.floor(price * GradingConfig.GradeMultipliers[grade] * 100 + 0.5) / 100
    end
    return price
end

