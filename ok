        if areaData.GarageIds then
            for id in pairs(areaData.GarageIds) do table.insert(garageIds, id) end
        elseif areaData.SimpleGarageId then
            table.insert(garageIds, areaData.SimpleGarageId)
        end
        for _, id in ipairs(garageIds) do
            local garageData = GarageConfig[id]
            if garageData then
                local entryCost = garageData.EntryCost and garageData.EntryCost.Min or 0
                local label = areaName .. " - " .. garageData.Name .. " ($" .. tostring(entryCost) .. ")"
                table.insert(garageEntries, {label = label, cost = entryCost, area = areaName, garageId = id})
            end
        end
    end
end
table.sort(garageEntries, function(a, b) return a.cost < b.cost end)
local garageOptions = {}
