local function fullGarageDump()
    if not canDestroy then return end
    local garages = workspace._Debris and workspace._Debris.Garages
    if not garages then return end
    local keepNames = { "Parts", "EntrySquare", "AuctionZone", "AuctioneerSpawn", "Floorspace", "Base" }
    for _, garage in ipairs(garages:GetChildren()) do
        if garage:IsA("Model") then
            local parts = garage:FindFirstChild("Parts")
            if parts then
                local toDestroy = {}
                for _, child in ipairs(parts:GetChildren()) do
                    if child.Name ~= "EntrySquare" then table.insert(toDestroy, child) end
                end
                for _, child in ipairs(toDestroy) do
                    pcall(function() child:Destroy() end)
                end
            end
            local toDestroy = {}
            for _, child in ipairs(garage:GetChildren()) do
                local shouldKeep = false
                for _, name in ipairs(keepNames) do
                    if child.Name == name then shouldKeep = true break end
                end
                if not shouldKeep then table.insert(toDestroy, child) end
            end
            for _, child in ipairs(toDestroy) do
                pcall(function() child:Destroy() end)
            end
        end
    end
end

